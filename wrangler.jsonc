{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "familyguyguysweb",
  "compatibility_date": "2026-07-10",
  "observability": {
    "enabled": true
  },

  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "html_handling": "single-page-app",
    "not_found_handling": "single-page-app"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
