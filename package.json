{
  "name": "familyguyguysweb",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node src/scripts/optimize-images.js && node src/scripts/generate-feed.js",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,html}\"",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.24.0",
    "p-limit": "^7.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.10.0",
    "eslint": "^9.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "sharp": "$sharp"
  }
}
